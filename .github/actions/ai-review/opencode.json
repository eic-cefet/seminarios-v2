{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": "deny",
    "write": "deny",
    "patch": "deny"
  },
  "provider": {
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    }
  },
  "mcp": {
    "github": {
      "type": "local",
      "command": [
        "docker", "run", "-i", "--rm",
        "-e", "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GH_MCP_TOKEN}"
      },
      "enabled": true
    }
  }
}
